# Escrow Service Configuration
# Copy to .env and adjust values for your environment.
# The setup script (npm run setup) generates .env automatically.

# ── General ──────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Database (PostgreSQL) ───────────────────────────────────
# Connection string for the escrow database.
# IMPORTANT: Change the password before any non-local deployment.
DATABASE_URL=postgresql://escrow:CHANGE_ME@localhost:5432/escrow_db

# Password used by Docker Compose for the postgres container.
POSTGRES_PASSWORD=CHANGE_ME

# ── Cache (Redis) ───────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# Password used by Docker Compose for the redis container.
REDIS_PASSWORD=CHANGE_ME

# ── Sphere Wallet ───────────────────────────────────────────
# Directory where the wallet keys and token data are stored.
SPHERE_WALLET_PATH=./.sphere-escrow

# HD derivation index for the escrow address (default 0).
SPHERE_ADDRESS_INDEX=0

# Network: testnet | mainnet | dev
# Default is testnet to avoid accidental mainnet usage.
SPHERE_NETWORK=testnet

# Nametag for the escrow service (e.g. "test-escrow-service").
# Traders can DM @test-escrow-service instead of using the raw DIRECT:// address.
# Registered during wallet init (npm run init-wallet). Leave empty to skip.
# WARNING: Changing this after initial registration does NOT re-register.
# The original nametag remains. Use a new wallet to change nametags.
SPHERE_NAMETAG=

# ── Swap Settings ───────────────────────────────────────────
# Minimum allowed swap timeout in seconds (default 60).
SWAP_TIMEOUT_MIN=60

# Maximum allowed swap timeout in seconds (default 86400 = 24h).
SWAP_TIMEOUT_MAX=86400

# Default swap timeout when not specified in manifest (default 3600 = 1h).
SWAP_TIMEOUT_DEFAULT=3600

# ── Payment Retry ──────────────────────────────────────────
# Max retry attempts for outgoing payments (default 3).
PAYMENT_RETRY_MAX_ATTEMPTS=3

# Delay between payment retries in milliseconds (default 5000).
PAYMENT_RETRY_DELAY_MS=5000

# ── Limits ──────────────────────────────────────────────────
# Maximum number of swaps in PENDING/DEPOSITING state (default 10000).
MAX_PENDING_SWAPS=10000

# How long to wait for deposit confirmation in milliseconds (default 60000).
DEPOSIT_CONFIRMATION_TIMEOUT_MS=60000
