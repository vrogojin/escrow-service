{
  "name": "@unicitylabs/escrow-service",
  "version": "0.1.0",
  "description": "Trusted escrow service for executing currency swaps on the Unicity network",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "tsx --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e-live": "vitest run --config vitest.e2e-live.config.ts",
    "typecheck": "tsc --noEmit",
    "setup": "bash scripts/setup.sh",
    "init-wallet": "tsx src/scripts/init-wallet.ts"
  },
  "dependencies": {
    "@unicitylabs/sphere-sdk": "file:../uxf",
    "canonicalize": "^2.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
